# ===================================
# Daily Stock Analysis 示例配置
# 复制本文件为 .env 后再填写真实值
# 注意：.env 不应提交到 GitHub
# ===================================

# -------------------------------
# Web / 服务基础配置
# -------------------------------
WEBUI_ENABLED=true
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000
LOG_LEVEL=INFO
TIMEZONE=Asia/Shanghai

# -------------------------------
# 默认自选股
# -------------------------------
STOCK_LIST=600519,300750,002594

# -------------------------------
# 大模型路由
# 可选：deepseek,chatgpt54,openai,ollama
# -------------------------------
LLM_CHANNELS=deepseek,chatgpt54
LITELLM_MODEL=openai/gpt-5.4
AGENT_LITELLM_MODEL=openai/gpt-5.4
LITELLM_FALLBACK_MODELS=deepseek/deepseek-chat,deepseek/deepseek-reasoner
LLM_TEMPERATURE=0.3

# ChatGPT 5.4 / OpenAI 兼容网关
LLM_CHATGPT54_ENABLED=true
LLM_CHATGPT54_PROTOCOL=openai
LLM_CHATGPT54_BASE_URL=http://your-openai-compatible-gateway/v1
LLM_CHATGPT54_API_KEY=sk-your-openai-compatible-key
LLM_CHATGPT54_MODELS=gpt-5.4

# DeepSeek
LLM_DEEPSEEK_ENABLED=true
LLM_DEEPSEEK_PROTOCOL=deepseek
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DEEPSEEK_API_KEY=sk-your-deepseek-key
LLM_DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# 可选：本地 Ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b

# -------------------------------
# 行情与数据源
# TickFlow 作为优先源，Tushare 作为辅助/回退
# -------------------------------
TICKFLOW_API_KEY=tk_your_tickflow_key

TUSHARE_TOKEN=your_tushare_token
# 如果你使用兼容网关，可改成自己的地址
TUSHARE_API_URL=http://your-tushare-compatible-gateway

# 可选：长桥等其他源
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=

# -------------------------------
# 新闻 / 搜索
# 至少配置一个，建议 Tavily + Bocha 双路
# -------------------------------
TAVILY_API_KEYS=tvly-your-tavily-key
BOCHA_API_KEYS=sk-your-bocha-key

# 可选补充搜索源
# ANSPIRE_API_KEYS=
# SERPAPI_API_KEYS=
# BRAVE_API_KEYS=
# SEARXNG_BASE_URLS=
# SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# 新闻过滤与缓存
NEWS_MAX_AGE_DAYS=3
NEWS_STRATEGY_PROFILE=short

# -------------------------------
# 飞书通知
# -------------------------------
FEISHU_ENABLED=true
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id
FEISHU_WEBHOOK_SECRET=your-feishu-secret

# -------------------------------
# 选股系统
# -------------------------------
STOCK_PICKER_ENABLED=true
STOCK_PICKER_MAX_CANDIDATES=10
STOCK_PICKER_REPORT_TOP_N=5
STOCK_PICKER_UNIVERSE=mainboard_non_st
STOCK_PICKER_DEFAULT_STRATEGY=mainboard_swing_master

# 每天收盘后自动跑“主力波段双模”
STOCK_PICKER_SCHEDULE_ENABLED=true
STOCK_PICKER_SCHEDULE_CRON=0 0 16 * * 1-5

# 数据缓存
DATA_CACHE_ENABLED=true
DATA_CACHE_DIR=./data/cache

# -------------------------------
# Agent 对话页
# -------------------------------
AGENT_MODE=true
AGENT_MAX_STEPS=10
AGENT_SKILLS=all

# -------------------------------
# 数据库
# -------------------------------
DATABASE_URL=sqlite:///./data/daily_stock_analysis.db

# -------------------------------
# 可选代理
# -------------------------------
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
